# Local bridge listener
CCB_BRIDGE_HOST=127.0.0.1
CCB_BRIDGE_PORT=8787

# Public model names exposed through Claude Code model slots
CCB_MODEL_SONNET=gpt-5.4
CCB_MODEL_OPUS=gpt-5.3-codex
CCB_MODEL_HAIKU=gpt-5.4-mini
CCB_MODEL_CUSTOM=gpt-5.2-codex
CCB_CUSTOM_MODEL_NAME=GPT-5.2-Codex
CCB_VENDOR_NAME=OpenAI

# Model string passed to the Claude client at startup.
# Some Claude Code versions only accept internal aliases such as "sonnet".
CCB_LAUNCH_MODEL=sonnet

# Optional explicit Codex model override.
# Leave empty to use the default model from the logged-in Codex CLI.
CCB_CODEX_MODEL=

# Extra flags appended to `codex exec`
CCB_CODEX_EXEC_ARGS=--full-auto

# Optional working directory override for Codex execution
CCB_WORKDIR=

# Optional Claude binary path override
CCB_CLAUDE_BIN=claude

# Optional Codex binary path override
CCB_CODEX_BIN=codex
